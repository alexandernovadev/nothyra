{
  "expo": {
    "name": "nothyra",
    "slug": "nothyra",
    "version": "2.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/AppIcons/Assets.xcassets/AppIcon.appiconset/1024.png",
    "scheme": "nothyra",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nova.nothyra"
    },
    "androidStatusBar": {
      "hidden": true,
      "backgroundColor": "#ffffff"
    },
    "androidNavigationBar": {
      "visible": "immersive"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.nova.nothyra",
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/AppIcons/Assets.xcassets/AppIcon.appiconset/1024.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/AppIcons/Assets.xcassets/AppIcon.appiconset/32.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/AppIcons/Assets.xcassets/AppIcon.appiconset/512.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "La app usa tu galería para la foto de la receta.",
          "cameraPermission": "La app puede usar la cámara para la foto de la receta."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30495d19-29e8-4cc7-96a1-a2a2a9c45109"
      }
    }
  }
}
